{
    "name": "reactive-context-toolkit",
    "version": "1.0.0",
    "private": false,
    "packageManager": "bun@1.3.10",
    "scripts": {
        "test": "bun test",
        "lint": "bun oxlint",
        "lint:": "bun oxlint --node-plugin --import-plugin --type-aware --type-check",
        "lint:fix": "bun lint --fix",
        "format:check": "prettier --check .",
        "format": "prettier --write .",
        "check": "bun format && bun lint:fix && bun test",
        "postinstall": "bun check"
    },
    "bin": {
        "rct": "./src/cli/index.ts"
    },
    "exports": {
        ".": "./src/index.ts"
    },
    "dependencies": {},
    "devDependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.2.84",
        "bun-types": "^1.3.11",
        "oxlint": "^1.58.0",
        "oxlint-tsgolint": "^0.18.1"
    },
    "prettier": {
        "arrowParens": "always",
        "bracketSpacing": true,
        "endOfLine": "lf",
        "objectWrap": "collapse",
        "semi": false,
        "singleQuote": true,
        "tabWidth": 4,
        "printWidth": 80,
        "embeddedLanguageFormatting": "auto",
        "experimentalTernaries": true,
        "experimentalOperatorPosition": "start"
    }
}
