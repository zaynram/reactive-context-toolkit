{
    "name": "reactive-context-toolkit",
    "version": "1.1.1",
    "private": false,
    "packageManager": "bun@1.3.10",
    "workspaces": [
        ".",
        "plugins/*"
    ],
    "scripts": {
        "test": "bun test",
        "lint": "bun oxlint --node-plugin --import-plugin --type-aware --type-check",
        "lint:fix": "bun lint --fix",
        "format:check": "prettier --check .",
        "format": "prettier --write .",
        "check": "bun format && bun lint:fix && bun test",
        "prepublish": "bun check",
        "publish": "git commit -a -m 'latest source code' && git push"
    },
    "bin": {
        "rct": "./src/cli/index.ts"
    },
    "exports": {
        ".": {
            "default": "./src/index.ts"
        }
    },
    "dependencies": {},
    "devDependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.2.112",
        "bun-types": "^1.3.12",
        "oxlint": "^1.60.0",
        "oxlint-tsgolint": "^0.18.1",
        "typescript": "^6.0.3"
    },
    "optionalDependencies": {
        "rct-plugin-tmux": "workspace:*",
        "rct-plugin-issue-scope": "workspace:*",
        "rct-plugin-track-work": "workspace:*",
        "rct-plugin-tasktools": "workspace:*",
        "rct-plugin-autonomous-ops": "workspace:*"
    },
    "prettier": {
        "arrowParens": "always",
        "bracketSpacing": true,
        "endOfLine": "lf",
        "objectWrap": "collapse",
        "semi": false,
        "singleQuote": true,
        "tabWidth": 4,
        "printWidth": 80,
        "embeddedLanguageFormatting": "auto",
        "experimentalTernaries": true,
        "experimentalOperatorPosition": "start"
    }
}
