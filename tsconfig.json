{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": { "#*": ["./src/*"] },
        "types": ["bun-types"]
    },
    "include": ["src", "test"],
    "exclude": ["node_modules", "lib"]
}
