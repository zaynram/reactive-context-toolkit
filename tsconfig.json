{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "#*": [
        "./src/*"
      ],
      "$*": [
        "./plugins/*"
      ]
    },
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "src",
    "test",
    "plugins"
  ],
  "exclude": [
    "node_modules",
    "lib"
  ]
}