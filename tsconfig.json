{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "declaration": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "rootDir": "src",
        "paths": {
            "#*": [
                "./src/*"
            ]
        },
        "types": [
            "bun-types",
        ]
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "lib",
        "test"
    ]
}